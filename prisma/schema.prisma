// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MessageType {
  text
  image
}

model User {
  id                 String               @id @default(uuid())
  username           String               @unique
  password_hash      String
  is_guest           Boolean              @default(false)
  created_at         DateTime             @default(now())
  messages           Message[] // the relation field (not a DB column, just for Prisma)
  conversationMember ConversationMember[] // the relation field (not a DB column, just for Prisma)
}

model Conversation {
  id                 String               @id @default(uuid())
  created_at         DateTime             @default(now())
  messages           Message[] // the relation field (not a DB column, just for Prisma)
  conversationMember ConversationMember[] // the relation field (not a DB column, just for Prisma)
}

// Junction table of Conversation and User
model ConversationMember {
  id              String       @id @default(uuid())
  joined_seq      BigInt
  left_seq        BigInt?
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id]) // the relation field (not a DB column, just for Prisma)
  user_id         String
  user            User         @relation(fields: [user_id], references: [id]) // the relation field (not a DB column, just for Prisma)

  @@unique([conversation_id, user_id, joined_seq])
}

model Message {
  id              String       @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id]) // the relation field (not a DB column, just for Prisma)
  from_user_id    String
  user            User         @relation(fields: [from_user_id], references: [id]) // the relation field (not a DB column, just for Prisma)
  body            String?
  type            MessageType
  metadata        Json?
  seq             BigInt
  created_at      DateTime     @default(now())
}
